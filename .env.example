# ============================================
# Parallax Intelligence — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values you need.
# All keys are optional — the dashboard works without them,
# but the corresponding features will be disabled.
#
#   cp .env.example .env.local
#
# ============================================


# ------ AI Summarization ------

# Groq API (primary — powers AI market insights and headline summarization)
# Free tier: 14,400 requests/day
# Get yours at: https://console.groq.com/
GROQ_API_KEY=

# Anthropic API (optional — enables deep second-order analysis on high-conviction signals)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=


# ------ Market Data ------

# Finnhub (live stock quotes, earnings, IPO data)
# Free tier: 60 requests/min
# Get yours at: https://finnhub.io/
FINNHUB_API_KEY=


# ------ Economic Data ------

# FRED (Federal Reserve Economic Data — GDP, CPI, unemployment, yield curves, VIX)
# Free, unlimited
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
