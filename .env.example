# All keys are optional — features degrade gracefully without them

# AI APIs
GROQ_API_KEY=           # https://console.groq.com — free tier: 14,400 req/day
ANTHROPIC_API_KEY=      # https://console.anthropic.com — for Claude deep analysis

# Market Data
FINNHUB_API_KEY=        # https://finnhub.io — free tier: 60 req/min

# Economic Data
FRED_API_KEY=           # https://fred.stlouisfed.org/docs/api/api_key.html — free

# Caching (optional, for production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase (local dev uses default values from supabase start)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
