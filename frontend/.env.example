# ============================================
# Parallax Intelligence — Frontend Environment
# ============================================
# Copy this file to .env.local and fill in the values you need.
# All keys are optional — features degrade gracefully without them.
#
#   cp .env.example .env.local
#
# ============================================


# ------ AI Summarization (Server-side) ------

# Groq API (primary — powers AI market insights and headline summarization)
# Free tier: 14,400 requests/day
# Get yours at: https://console.groq.com/
GROQ_API_KEY=

# OpenRouter API (fallback LLM provider if Groq is unavailable)
# Free tier: 50 requests/day
# Get yours at: https://openrouter.ai/
OPENROUTER_API_KEY=


# ------ Market Data (Server-side) ------

# Finnhub (live stock quotes, earnings, IPO data)
# Free tier: 60 requests/min
# Get yours at: https://finnhub.io/
FINNHUB_API_KEY=


# ------ Economic Data (Server-side) ------

# FRED (Federal Reserve Economic Data — GDP, CPI, yields, VIX, unemployment)
# Free, unlimited
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=


# ------ Caching (Optional) ------

# Upstash Redis — used to cache AI responses and deduplicate API calls
# Create a free database at: https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ------ Self-Hosted LLM (Optional) ------

# Point to a local Ollama instance for offline AI summarization
# Download at: https://ollama.com/download
OLLAMA_API_URL=
OLLAMA_MODEL=


# ------ Site Configuration ------

# Variant (leave as finance for this project)
VITE_VARIANT=finance
